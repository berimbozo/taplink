# URL of your Railway backend (no trailing slash)
VITE_API_BASE_URL=https://your-app.up.railway.app

# Must match ADMIN_API_KEY set on the backend (used silently for API auth — never typed by the user)
VITE_ADMIN_API_KEY=your_secret_admin_key_here

# A memorable password for the admin portal login screen (you choose this — keep it private)
VITE_ADMIN_PASSWORD=your_memorable_password_here
# ─── Google Places ────────────────────────────────────────────────────────────
# Your Google Cloud API key (restrict it to Places API in Google Cloud Console)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Your gym's Google Place ID (looks like: ChIJN1t_tDeuEmsRUsoyG83frY4)
# Find it at: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
GOOGLE_PLACE_ID=ChIJ_your_place_id_here

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Get this from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── Admin Security ───────────────────────────────────────────────────────────
# A secret string you invent — used to protect POST routes in the admin portal
# Example: openssl rand -hex 32
ADMIN_API_KEY=your_secret_admin_key_here

# ─── URLs ─────────────────────────────────────────────────────────────────────
# The public URL of this Railway backend (set after first deploy)
API_BASE_URL=https://your-app.up.railway.app

# The URL of your admin portal (for CORS — set after deploying the portal)
ADMIN_PORTAL_URL=https://your-admin.up.railway.app

# ─── Database ─────────────────────────────────────────────────────────────────
# Auto-provided by Railway when you add a Postgres plugin — do not edit manually
DATABASE_URL=postgresql://user:password@host:port/dbname